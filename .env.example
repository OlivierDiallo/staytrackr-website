# ─── Resend (email) ───────────────────────────────────────────────
# Get your API key at https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here

# The "from" address — must use a domain you verified in Resend
# Until you verify a domain, use: onboarding@resend.dev (test only)
RESEND_FROM=StayTrackr <socials@getstaytrackr.com>

# Optional: Resend Audience ID for list management + unsubscribe links
# Create an audience at https://resend.com → Audiences, then paste the ID here
RESEND_AUDIENCE_ID=

# ─── Admin ────────────────────────────────────────────────────────
ADMIN_PASSWORD=staytrackr-admin

# ─── Server ───────────────────────────────────────────────────────
PORT=3000
